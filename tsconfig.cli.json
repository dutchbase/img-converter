{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "dist/cli",
    "rootDir": ".",
    "noEmit": false,
    "target": "ES2020",
    "lib": ["ES2020"],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["cli/**/*.ts", "lib/**/*.ts", "types/**/*.ts"],
  "exclude": ["node_modules", "app", "components", "__tests__", "dist"]
}
